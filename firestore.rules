rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isMember(familyId) {
      return isSignedIn() && userDoc().data.familyId == familyId;
    }

    function isParent(familyId) {
      return isMember(familyId) && userDoc().data.role == 'parent';
    }

    // inviteCodes/{code} -> { familyId }
    // Public read so a not-yet-signed-up family member can look up which
    // family an invite code belongs to. Contains no private data.
    match /inviteCodes/{code} {
      allow read: if true;
      allow create: if isSignedIn();
    }

    // parentLookup/{emailLowercased} -> { familyId }
    // Public read so a signed-out parent doing "forgot password" can verify
    // their email + join code belong to the same family before we trigger
    // Firebase's built-in reset email. Contains no private data (mirrors
    // inviteCodes above). Write is allowed for any signed-in user since a
    // mismatched/malicious write only affects which address a standard
    // Firebase reset email might later be sent to, not account access.
    match /parentLookup/{email} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // users/{uid} -> { familyId, role }
    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && request.auth.uid == uid;
    }

    match /families/{familyId} {
      allow read: if isMember(familyId);
      // Family doc itself is created once by whoever starts the family.
      allow create: if isSignedIn();
      allow update: if isParent(familyId);

      match /members/{memberUid} {
        // Kid records are also readable by any signed-in (incl. anonymous)
        // user so a kid claiming their profile by name + join code can find
        // it before they're a member. Accepted tradeoff: knowing a family's
        // join code lets you see that family's kid names, same trust level
        // as the join code itself.
        allow read: if isMember(familyId)
          || (isSignedIn() && resource.data.role == 'kid');
        allow create: if isSignedIn() && request.auth.uid == memberUid;
        // A parent can edit/remove members normally. A kid-claim (anonymous
        // or otherwise) may only ever touch the `claimedUid` pointer on an
        // existing kid record — never role, name, or anything else.
        allow update: if isParent(familyId)
          || (isSignedIn() && resource.data.role == 'kid'
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['claimedUid']));
        allow delete: if isParent(familyId);
      }

      match /chores/{choreId} {
        allow read: if isMember(familyId);
        allow create, update, delete: if isParent(familyId);
      }

      match /ledger/{entryId} {
        allow read: if isMember(familyId);
        // Kids can create pending chore entries; only parents approve/edit/delete.
        allow create: if isMember(familyId);
        allow update, delete: if isParent(familyId);
      }

      match /requests/{requestId} {
        allow read: if isMember(familyId);
        allow create: if isMember(familyId);
        allow update, delete: if isParent(familyId);
      }

      match /goal/{docId} {
        allow read: if isMember(familyId);
        allow write: if isParent(familyId);
      }
    }
  }
}
